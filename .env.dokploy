SUPABASE_JWT_SECRET=


# =============================================================================
# LLM PROVIDERS  (at least one required)
# =============================================================================

# REQUIRED — fill in Dokploy dashboard
# Anthropic Claude API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# REQUIRED — fill in Dokploy dashboard
# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=


# =============================================================================
# SANDBOX
# =============================================================================

# E2B sandbox API key for secure code execution
E2B_API_KEY=e2b_998335999943beb1cbfbc8c05c7353ee2d1ab07e


# =============================================================================
# SEARCH & WEB CRAWL
# =============================================================================

TAVILY_API_KEY=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
FIRECRAWL_API_KEY=fc-11fb48f531124edf8e18aa59693a4a79
FIRECRAWL_URL=https://api.firecrawl.dev


# =============================================================================
# REDIS  (internal — matches docker-compose service name)
# =============================================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL=False


# =============================================================================
# BIM-SPECIFIC SETTINGS
# =============================================================================

# Paths inside the container to BIM reference data
BIM_CARBON_DATABASE_PATH=/data/carbon_factors.json
BIM_THAI_CODES_PATH=/data/thai_building_codes.json

# Maximum IFC upload size in MB
BIM_MAX_FILE_SIZE_MB=500


# =============================================================================
# DOKPLOY CLI CREDENTIALS
# =============================================================================

# Your Dokploy server URL (the panel address, e.g. https://panel.yourdomain.com)
# REQUIRED — set this before running any dokploy-cli-* targets
DOKPLOY_SERVER_URL=http://20.55.21.69:3000

# Dokploy access token (Settings → Profile → Generate in the dashboard)
DOKPLOY_TOKEN=aDYMjpEyYiDyKbQgsDwkKiUyegSHdDInGcSiobZagvjmHCPTwSdWCJRhyfPYDJwn


ENV_MODE=production


# =============================================================================
# FRONTEND BUILD ARGS  (baked into Next.js bundle at build time)
# =============================================================================

# Supabase public URL — same as SUPABASE_URL above
NEXT_PUBLIC_SUPABASE_URL=https://vplbjxijbrgwskgxiukd.supabase.co

# Supabase anonymous key — same as SUPABASE_ANON_KEY above
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZwbGJqeGlqYnJnd3NrZ3hpdWtkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI3Mjc2MjQsImV4cCI6MjA4ODMwMzYyNH0.l35Qo5-A1yqi4xS044TLQc_WhT3-vwFZu7wOEwErMGU

# REQUIRED — fill in Dokploy dashboard
# Full URL to your backend API, including /v1 path prefix
# Example: https://suna-bim.yourdomain.com/api/v1
NEXT_PUBLIC_BACKEND_URL=

# REQUIRED — fill in Dokploy dashboard
# Public URL of the frontend (used for OAuth redirects, meta tags, etc.)
# Example: https://suna-bim.yourdomain.com
NEXT_PUBLIC_URL=

NEXT_PUBLIC_ENV_MODE=production

# Use --frozen-lockfile in production builds for reproducibility
PNPM_LOCKFILE_MODE=--no-frozen-lockfile
