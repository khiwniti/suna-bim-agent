# =============================================================================
# Carbon BIM Environment Configuration Template
# =============================================================================
# Copy this file to .env.local and fill in the required values
# Never commit .env.local to version control (it's gitignored)
#
# Required variables are marked with [REQUIRED]
# Optional variables have default values or are only needed for specific features
# =============================================================================

# =============================================================================
# Environment Mode [REQUIRED]
# =============================================================================
# Options: local, staging, production
# Controls which configuration profiles to use (Stripe tiers, frontend URLs, etc.)
ENV_MODE=local

# =============================================================================
# Supabase Configuration [REQUIRED]
# =============================================================================
# Get these from your Supabase project settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Webhook secret for Supabase database webhooks (optional)
SUPABASE_WEBHOOK_SECRET=

# =============================================================================
# Redis Configuration [REQUIRED]
# =============================================================================
# For local development, use default values (localhost Redis)
# For production, use managed Redis (Upstash, AWS ElastiCache, etc.)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_MAX_CONNECTIONS=300
REDIS_SSL=false

# Redis timeout configuration (optional, in seconds)
# REDIS_STREAM_ADD_TIMEOUT=5
# REDIS_XACK_TIMEOUT=5
# REDIS_XREADGROUP_TIMEOUT=10

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Primary LLM provider selection
# Options: bedrock, anthropic, openai, grok, minimax, github
MAIN_LLM=bedrock

# Optional: Override default model for the selected provider
# If not set, uses provider defaults (e.g., claude-haiku-4-5 for anthropic)
# MAIN_LLM_MODEL=

# LLM API Keys (at least one required based on MAIN_LLM choice)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
MORPH_API_KEY=

# GitHub Models (Azure AI inference)
GH_MODELS_TOKEN=

# OpenAI-compatible custom endpoints
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_API_BASE=

# OpenRouter configuration
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OR_SITE_URL=http://localhost:3000
OR_APP_NAME=Carbon BIM

# AWS Bedrock authentication
# AWS_BEARER_TOKEN_BEDROCK=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-west-2

# =============================================================================
# Sandbox Configuration
# =============================================================================
# E2B sandbox for code execution (recommended)
E2B_API_KEY=

# Daytona sandbox (legacy, no longer actively used)
# DAYTONA_API_KEY=
# DAYTONA_SERVER_URL=
# DAYTONA_TARGET=

# Sandbox pool configuration (optional, production optimization)
# SANDBOX_POOL_ENABLED=false
# SANDBOX_POOL_MIN_SIZE=2
# SANDBOX_POOL_MAX_SIZE=10
# SANDBOX_POOL_REPLENISH_THRESHOLD=0.3
# SANDBOX_POOL_CHECK_INTERVAL=30
# SANDBOX_POOL_MAX_AGE=3600
# SANDBOX_POOL_PARALLEL_CREATE=3
# SANDBOX_POOL_BATCH_DELAY=5

# =============================================================================
# BIM Configuration
# =============================================================================
# Maximum IFC file upload size in MB (default: 500MB)
BIM_MAX_FILE_SIZE_MB=500

# Carbon database and Thai building codes (paths within container)
# BIM_CARBON_DATABASE_PATH=/data/carbon_factors.json
# BIM_THAI_CODES_PATH=/data/thai_building_codes.json

# BOQ analysis model (default: claude-3-5-sonnet)
# BOQ_ANALYSIS_MODEL=anthropic/claude-3-5-sonnet-20241022

# =============================================================================
# Search & Research Tools (Optional)
# =============================================================================
# Web search (at least one recommended for agent capabilities)
TAVILY_API_KEY=
SERPER_API_KEY=
RAPID_API_KEY=

# Academic search
# SEMANTIC_SCHOLAR_API_KEY=

# Web scraping and crawling
# FIRECRAWL_API_KEY=
# FIRECRAWL_URL=https://api.firecrawl.dev
# APIFY_API_TOKEN=

# Advanced search (optional)
# EXA_API_KEY=

# =============================================================================
# Image & Media Generation (Optional)
# =============================================================================
# Replicate for image generation models
REPLICATE_API_TOKEN=

# Mock image generation for testing (true/false)
# MOCK_IMAGE_GENERATION=false

# =============================================================================
# Stripe Payment Configuration (Optional)
# =============================================================================
# Required only if enabling paid subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_PLAN_ID=
STRIPE_DEFAULT_TRIAL_DAYS=14

# RevenueCat (mobile app subscriptions)
# REVENUECAT_WEBHOOK_SECRET=
# REVENUECAT_API_KEY=
# REVENUECAT_PROJECT_ID=

# =============================================================================
# Security & Encryption
# =============================================================================
# Admin API key (auto-generated if not provided)
# CARBON_BIM_ADMIN_API_KEY=

# API key encryption
API_KEY_SECRET=default-secret-key-change-in-production
API_KEY_LAST_USED_THROTTLE_SECONDS=900

# MCP credential encryption
# MCP_CREDENTIAL_ENCRYPTION_KEY=
# ENCRYPTION_KEY=

# =============================================================================
# Integrations & Webhooks
# =============================================================================
# Composio integration
# COMPOSIO_API_KEY=
# COMPOSIO_API_BASE=https://backend.composio.dev
# COMPOSIO_WEBHOOK_SECRET=

# Generic trigger webhooks
# TRIGGER_WEBHOOK_SECRET=
# WEBHOOK_BASE_URL=

# Vercel protection bypass
# VERCEL_PROTECTION_BYPASS_KEY=

# =============================================================================
# Frontend Configuration
# =============================================================================
# Frontend URL (auto-detected based on ENV_MODE if not set)
# Local: http://localhost:3000
# Staging/Production: configured per environment
# FRONTEND_URL=

# =============================================================================
# Observability & Monitoring
# =============================================================================
# LangFuse (LLM observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Google Analytics (GA4)
# GA_PROPERTY_ID=
# GA_CREDENTIALS_JSON=

# Vercel Analytics drains
# VERCEL_DRAIN_SECRET=

# CloudWatch Logs
# CLOUDWATCH_LOG_GROUP=carbon-bim-logs

# Sentry error tracking and performance monitoring
# Get DSN from: https://sentry.io/settings/[organization]/projects/[project]/keys/
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# =============================================================================
# Agent Configuration
# =============================================================================
# Agent execution behavior
AGENT_XML_TOOL_CALLING=false
AGENT_NATIVE_TOOL_CALLING=true
AGENT_EXECUTE_ON_STREAM=true
AGENT_TOOL_EXECUTION_STRATEGY=parallel

# Agent limits (overrides per-tier defaults if set)
# MAX_PARALLEL_AGENT_RUNS=

# System admin user ID (owns shared/fallback agents)
# SYSTEM_ADMIN_USER_ID=

# =============================================================================
# Features & Capabilities
# =============================================================================
# Memory and context
ENABLE_MEMORY=false
ENABLE_KNOWLEDGE_BASE=true
ENABLE_USER_CONTEXT=true
ACTIVATE_MCPS_TRIG=true

# Memory embedding configuration
MEMORY_EMBEDDING_PROVIDER=openai
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EXTRACTION_MODEL=carbon-bim/basic

# Voice API (optional)
# VAPI_PRIVATE_KEY=
# VAPI_PHONE_NUMBER_ID=
# VAPI_SERVER_URL=

# Presence tracking
DISABLE_PRESENCE=true

# =============================================================================
# Freestyle Deployment (Optional)
# =============================================================================
# FREESTYLE_API_KEY=

# =============================================================================
# Advanced Security Tools (Optional)
# =============================================================================
# Reality Defender (deepfake detection)
# REALITY_DEFENDER_API_KEY=

# Cloudflare
# CLOUDFLARE_API_TOKEN=

# =============================================================================
# Debug & Development
# =============================================================================
# Save LLM API calls to debug_streams/ (always false in production)
# DEBUG_SAVE_LLM_IO=false

# Stress testing
# STRESS_TEST_BASE_URL=http://localhost:8000

# Recovery shard configuration (for distributed recovery)
# RECOVERY_SHARD_ID=0
# RECOVERY_TOTAL_SHARDS=1

# =============================================================================
# Cache Configuration
# =============================================================================
# Redis-based caching for expensive computations (carbon calculations, IFC parsing)
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=3600
CACHE_CARBON_TTL=3600
CACHE_IFC_TTL=86400
CACHE_MAX_SIZE_MB=1024

# =============================================================================
# Rate Limiting Configuration
# =============================================================================
# Rate limits for BIM operations (requests per minute)
# RATE_LIMIT_BIM_UPLOAD=10/minute
# RATE_LIMIT_BIM_ANALYSIS=5/minute
# RATE_LIMIT_AGENT_START=20/minute
# RATE_LIMIT_BOQ_ANALYSIS=3/minute

# =============================================================================
# Notes
# =============================================================================
# 1. Copy this file to .env.local and fill in required values
# 2. Never commit .env.local to git (it's automatically gitignored)
# 3. For production, use environment-specific secrets management
# 4. Stripe tier IDs are hardcoded in core/utils/config.py (env-specific)
# 5. See CLAUDE.md for complete setup instructions
# =============================================================================
